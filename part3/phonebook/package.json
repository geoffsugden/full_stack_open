{
  "name": "phonebook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "json-server -p 3001 db.json",
    "build:ui": "rm -rf dist && cd ../phonebook && npm run build && cp -r dist ../phonebook_server",
    "deploy:full": "npm run build:ui && git add . && git commit -a -m uibuild && git push"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "mongoose": "^9.6.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "json-server": "^1.0.0-beta.15",
    "vite": "^8.0.4"
  }
}
